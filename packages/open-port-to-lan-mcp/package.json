{
    "name": "open-port-to-lan-mcp",
    "version": "1.0.0",
    "description": "Windows MCP HTTP server that temporarily opens local ports for inbound LAN access via Windows Firewall",
    "type": "module",
    "main": "dist/server.js",
    "bin": {
        "open-port-to-lan-mcp": "dist/server.js"
    },
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "test": "vitest run",
        "bundle": "esbuild src/server.ts --bundle --outfile=bundle/server.cjs --platform=node --format=cjs --target=node20",
        "package:exe": "pnpm bundle && pkg bundle/server.cjs --target node20-win-x64 --output release/open-port-to-lan-mcp.exe"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.8.0",
        "dotenv": "^16.4.0",
        "express": "^4.21.0",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^22.0.0",
        "@yao-pkg/pkg": "^5.12.0",
        "esbuild": "^0.25.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "vitest": "^3.2.0"
    }
}