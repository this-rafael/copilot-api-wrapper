# Port the MCP HTTP server listens on
PORT=3741

# Shared secret – clients must send: Authorization: Bearer <token>
MCP_AUTH_TOKEN=change-me-before-use

# Optional comma-separated IPv4 allowlist (leave empty to allow any IP on the LAN)
# ALLOWED_IPS=192.168.1.10,192.168.1.20

# Path to the JSON file used to persist open-rule state
STATE_PATH=state/open-rules.json

# Maximum TTL allowed per tool call (seconds). Default: 3600 (1 hour)
MAX_TTL_SECONDS=3600

# Minimum TTL required per tool call (seconds). Default: 60
MIN_TTL_SECONDS=60

# How often to scan for expired rules and remove them (milliseconds). Default: 30000
CLEANUP_INTERVAL_MS=30000
