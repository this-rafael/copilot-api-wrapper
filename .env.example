# Port the WebSocket server listens on
PORT=3000

# Port the Vite client listens on during development
CLIENT_PORT=5173

# Host the Vite client binds to during development and preview
CLIENT_HOST=0.0.0.0

# Secret token clients must send in the Authorization header (Bearer <token>)
WS_AUTH_TOKEN=your-secret-token-here

# Comma-separated list of absolute paths that are allowed as session cwd
# Example: /home/user/projects,/tmp/sandbox
ALLOWED_CWDS=/home/user/projects

# SQLite database used to persist custom workspaces added from the UI
CUSTOM_CWDS_DB_PATH=artifacts/custom-cwds.sqlite

# Session inactivity timeout in milliseconds (default: 30 minutes)
SESSION_TIMEOUT_MS=1800000

# Maximum number of concurrent sessions allowed
MAX_SESSIONS=10

# Optional: override the host used by the client when pre-filling the WebSocket URL
# VITE_BACKEND_HOST=127.0.0.1

# Optional: force a complete default WebSocket URL in the client instead of composing from host + PORT
# VITE_WS_URL=ws://127.0.0.1:3000
